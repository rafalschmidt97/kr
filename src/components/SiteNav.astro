---
// Top navigation for interior pages (dark links on white background).
import PreviewPanel from "./PreviewPanel.astro";
interface Props {
  current?: "historia";
}
const { current } = Astro.props;
---

<div class="nav-group">
  <nav class="nav">
    <a href="/#plan">Plan</a>
    <a href="/#faq">FAQ</a>
    <a
      href="/historia"
      aria-current={current === "historia" ? "page" : undefined}
      >Nasza historia</a
    >
  </nav>
  <PreviewPanel variant="light" />
</div>

<style>
  .nav-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 0 0 2.5rem;
  }
  /* Light glass pill — mirrors the hero pill, but tuned for white pages. */
  .nav {
    display: flex;
    gap: 2.5rem;
    justify-content: center;
    align-items: center;
    flex-wrap: nowrap;
    white-space: nowrap;
    max-width: calc(100% - 2rem);
    padding: 0.85rem 2rem;
    font-size: 0.9rem;
    border-radius: 999px;
    background: rgba(24, 24, 27, 0.045);
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
  }
  .nav a {
    color: inherit;
    text-decoration: none;
    opacity: 0.75;
    white-space: nowrap;
  }
  .nav a:hover,
  .nav a[aria-current="page"] {
    opacity: 1;
    text-decoration: underline;
  }

  @media screen and (max-width: 768px) {
    .nav {
      gap: 1.1rem;
      padding: 0.7rem 1.25rem;
      font-size: 0.8rem;
    }
  }
</style>
