---
// Top navigation for interior pages (dark links on white background).
interface Props {
  current?: "historia";
}
const { current } = Astro.props;
---

<nav class="nav">
  <a href="/#plan">Plan</a>
  <a href="/#faq">FAQ</a>
  <a href="/historia" aria-current={current === "historia" ? "page" : undefined}
    >Nasza historia</a
  >
</nav>

<style>
  .nav {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    flex-wrap: wrap;
    padding: 0 0 2.5rem;
    font-size: 0.9rem;
  }
  .nav a {
    color: inherit;
    text-decoration: none;
    opacity: 0.75;
  }
  .nav a:hover,
  .nav a[aria-current="page"] {
    opacity: 1;
    text-decoration: underline;
  }
</style>
