---
// Optional, consent-gated Google Analytics.
// Enabled only when PUBLIC_GA_ID is set. With no ID, nothing renders
// (no analytics script, no analytics consent banner).
const gaId = import.meta.env.PUBLIC_GA_ID;
---

{
  gaId && (
    <div
      id="cookie-consent"
      class="glass-panel consent"
      role="dialog"
      aria-live="polite"
      aria-label="Zgoda na pliki cookie"
      data-ga-id={gaId}
      hidden
    >
      <p class="consent__text">
        Ta strona używa plików cookie od zewnętrznych dostawców w celu analizy
        ruchu.
      </p>
      <div class="consent__actions">
        <button
          type="button"
          id="consent-accept"
          class="consent__btn consent__btn--accept"
        >
          Zaakceptuj
        </button>
        <button
          type="button"
          id="consent-reject"
          class="consent__btn consent__btn--reject"
        >
          Odrzuć
        </button>
      </div>
    </div>
  )
}

<script>
  import { initConsentAnalytics } from "../scripts/consent";

  const banner = document.getElementById("cookie-consent");
  const gaId = banner?.dataset.gaId;
  if (gaId) initConsentAnalytics(gaId);
</script>

<style>
  .consent {
    right: 4.5rem;
    bottom: 4.5rem;
  }
  @media screen and (max-width: 768px) {
    .consent {
      left: 1rem;
      right: 1rem;
      bottom: 1.5rem;
      max-width: none;
    }
  }
  .consent__text {
    margin: 0 0 0.7rem;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }
  .consent__actions {
    display: flex;
    gap: 0.5rem;
  }
  .consent__btn {
    flex: 1;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.45rem 0.75rem;
    cursor: pointer;
    font-size: 0.8rem;
    border-radius: 8px;
    transition:
      background 0.2s,
      color 0.2s;
  }
  .consent__btn--accept {
    background: rgba(255, 255, 255, 0.9);
    color: #000;
  }
  .consent__btn--accept:hover {
    background: #fff;
  }
  .consent__btn--reject {
    background: transparent;
    color: #fff;
  }
  .consent__btn--reject:hover {
    background: rgba(255, 255, 255, 0.15);
  }
</style>
