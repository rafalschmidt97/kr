---
// Preview control: a "⋯ more" button that only appears when preview mode is on
// (?preview=1). It reveals links to the hidden guest-group and schedule pages,
// plus a switch to turn preview off. Rendered inline inside the nav pill.
import { groups } from "../data/groups";
import { schedules } from "../data/schedules";
---

<div id="preview-more" class="preview-more" hidden>
  <button
    type="button"
    id="preview-more-btn"
    class="preview-more__btn"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="preview-more-menu"
    aria-label="Więcej — podgląd ukrytych stron">⋯</button
  >
  <div id="preview-more-menu" class="preview-more__menu" hidden>
    <p class="preview-more__label">Goście</p>
    {groups.map((g) => <a href={`/${g.slug}`}>{g.label}</a>)}
    <p class="preview-more__label">Harmonogramy</p>
    {
      schedules.map((s) => (
        <a href={`/${s.slug}`}>{s.previewLabel ?? s.label}</a>
      ))
    }
    <button type="button" id="preview-off" class="preview-more__off">
      Wyłącz podgląd
    </button>
  </div>
</div>

<script>
  import { initPreview } from "../scripts/preview";
  initPreview();
</script>

<style>
  .preview-more {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .preview-more[hidden] {
    display: none;
  }
  .preview-more__btn {
    background: none;
    border: none;
    color: inherit;
    opacity: 0.75;
    font-size: 1.15rem;
    line-height: 1;
    letter-spacing: 0.04em;
    cursor: pointer;
    padding: 0 0.15rem;
  }
  .preview-more__btn:hover,
  .preview-more__btn[aria-expanded="true"] {
    opacity: 1;
  }

  /* Self-contained dark glass dropdown — readable over both hero and white. */
  .preview-more__menu {
    position: absolute;
    top: calc(100% + 0.85rem);
    right: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: max-content;
    padding: 0.85rem 1.1rem;
    border-radius: 14px;
    text-align: left;
    white-space: nowrap;
    background: rgba(24, 24, 27, 0.92);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.32);
  }
  .preview-more__menu[hidden] {
    display: none;
  }
  .preview-more__label {
    margin: 0.15rem 0 0;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.45);
  }
  .preview-more__label:first-child {
    margin-top: 0;
  }
  .preview-more__menu a {
    color: #fff;
    opacity: 0.9;
    font-size: 0.85rem;
    text-decoration: none;
  }
  .preview-more__menu a:hover {
    opacity: 1;
    text-decoration: underline;
  }
  .preview-more__off {
    margin-top: 0.35rem;
    padding-top: 0.6rem;
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    background: none;
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.8rem;
    text-align: left;
    cursor: pointer;
  }
  .preview-more__off:hover {
    color: #fff;
  }
</style>
