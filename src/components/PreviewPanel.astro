---
import { groups } from "../data/groups";
---

<aside id="preview-panel" class="glass-panel preview" hidden>
  <p class="preview__title">Podgląd (tylko dla nas)</p>
  <ul class="preview__list">
    {
      groups.map((g) => (
        <li>
          <a href={`/${g.slug}`}>{g.label}</a>
        </li>
      ))
    }
  </ul>
</aside>

<script>
  import { initPreview } from "../scripts/preview";
  initPreview();
</script>

<style>
  .preview {
    left: 4.5rem;
    bottom: 4.5rem;
    max-width: 16rem;
  }
  @media screen and (max-width: 768px) {
    .preview {
      left: 1rem;
      bottom: 1rem;
    }
  }
  .preview__title {
    margin: 0 0 0.5rem;
    font-weight: 600;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 0.7rem;
  }
  .preview__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .preview__list li {
    padding: 0.2rem 0;
  }
  .preview__list a {
    color: #fff;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }
</style>
