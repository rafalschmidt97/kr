---
interface Props {
  id: string;
  title: string;
}
const { id, title } = Astro.props;
---

<section id={id} class="section">
  <div class="section__inner">
    <h2 class="section__title">{title}</h2>
    <slot />
  </div>
</section>

<style>
  .section {
    scroll-margin-top: 4rem;
    padding: 3.5rem 1.25rem;
  }
  .section:nth-of-type(even) {
    background: #faf8f6;
  }
  .section__inner {
    max-width: 640px;
    margin: 0 auto;
  }
  .section__title {
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 1px;
    margin: 0 0 1.5rem;
    text-align: center;
  }
</style>
