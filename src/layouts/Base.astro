---
import Analytics from "../components/Analytics.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = "Klaudia & Rafał",
  description = "Hej! Tu Klaudia i Rafał. Nasze wesele odbędzie się 10 lipca 2027 w Villa Presto.",
  image = "/static/avatar.png",
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const imageUrl = new URL(image, Astro.site).href;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />
    <link rel="canonical" href={canonical} />

    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/assets/images/apple-touch-icon.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/assets/images/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/assets/images/favicon-16x16.png"
    />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="800" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <slot name="head" />
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>

<style is:global>
  :root {
    --color-fg: rgba(0, 0, 0, 0.87);
    --color-bg: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-size: 100%;
  }

  body {
    margin: 0;
    padding: 0;
    color: var(--color-fg);
    background: var(--color-bg);
    font-family:
      "Manrope",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Helvetica,
      Arial,
      sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
  }

  /* Shared "liquid glass" floating panel — used by the cookie consent banner
     and the preview panel. Dark translucent glass so white text stays legible
     over both dark photos and white sections. Position set by the component. */
  .glass-panel {
    position: fixed;
    bottom: 1rem;
    z-index: 1000;
    max-width: 20rem;
    padding: 0.9rem 1rem;
    border-radius: 14px;
    font-size: 0.8rem;
    line-height: 1.45;
    color: #fff;
    background: rgba(24, 24, 27, 0.55);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.28);
    animation: glass-in 0.4s ease-out;
  }
  @supports not (
    (backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))
  ) {
    .glass-panel {
      background: rgba(24, 24, 27, 0.92);
    }
  }
  @keyframes glass-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .glass-panel[hidden] {
    display: none;
  }
</style>
